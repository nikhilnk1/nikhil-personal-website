---
import Base from '../layouts/Base.astro';
---

<Base title="Recognition" description="Awards, honours, delegations, and media recognition for Nikhil Kulkarni.">

  <div class="page-header">
    <h1>Recognition & Honours</h1>
    <p class="intro">Recognised at key awards and honours, selected for prestigious delegations and programs, and invited to represent causes in cricket, community, and Australia–India engagement.</p>
  </div>

  <div class="content">

    <nav class="pill-nav" aria-label="Jump to section">
      <a href="#ambassador" class="pill">Ambassador Roles</a>
      <a href="#awards" class="pill">Awards & Honours</a>
      <a href="#programs" class="pill">Programs & Delegations</a>
    </nav>

    <section class="rec-section" id="ambassador">
      <span class="rec-label">Ambassador Roles</span>
      <div class="rec-items">
        <div class="rec-item">
          <div class="rec-item-title"><a href="https://www.facebook.com/thelbwtrust/photos/what-do-australian-cricketer-sean-abbott-tech-leader-nikhil-kulkarni-and-cricket/1267216168879857/" target="_blank" rel="noopener">Ambassador, The LBW Trust</a> · 2026</div>
          <div class="rec-item-detail">The LBW Trust is a cricket-funded charity supporting education across India, Nepal, Sri Lanka, and Australia. Alongside international cricketers.</div>
        </div>
        <div class="rec-item">
          <div class="rec-item-title"><a href="https://www.facebook.com/TheIABCA/photos/-iabca-ambassador-announcement-2026-nikhil-kulkarni-we-are-pleased-to-welcome-ni/1681391716745642/" target="_blank" rel="noopener">Ambassador, India Australia Business &amp; Community Alliance (IABCA)</a> · 2026</div>
          <div class="rec-item-detail">IABCA brings together a distinguished network of leaders shaping the Australia–India corridor across technology, entrepreneurship, and community. Part of the IABCA Ambassador Circle.</div>
        </div>
      </div>
    </section>

    <section class="rec-section" id="awards">
      <span class="rec-label">Awards &amp; Honours</span>
      <div class="rec-items">
        <div class="rec-item">
          <div class="rec-item-title"><a href="https://www.iabca.com.au/2026finalists" target="_blank" rel="noopener">India-Australia Business Community Alliance (IABCA) Awards, Finalist</a> · 2026</div>
          <div class="rec-item-detail">Emerging Leader of the Year category. Recognises exceptional achievements of an emerging leader making a significant impact in their field. Assessed on leadership potential, innovation, and commitment to professional growth across professionals in middle and senior management roles.</div>
        </div>
        <div class="rec-item">
          <div class="rec-item-title"><a href="https://www.asianaustralianleadership.com.au/awards/2024-winners" target="_blank" rel="noopener">Asian Australian Leadership Awards, Finalist</a> · 2024</div>
          <div class="rec-item-detail">Corporate Category. The Asian-Australian Leadership Awards celebrate the valuable contributions that Asian-Australians bring to Australia, recognising leaders across corporate, government, community, and creative sectors.</div>
        </div>
        <div class="rec-item">
          <div class="rec-item-title"><a href="https://immi.homeaffairs.gov.au/visas/getting-a-visa/visa-listing/national-innovation-visa-858" target="_blank" rel="noopener">National Innovation Visa</a> (formerly Global Talent Independent Visa) · 2021</div>
          <div class="rec-item-detail">Awarded by the Australian Government. Granted only to individuals recognised as exceptional global talent.</div>
        </div>
      </div>
    </section>

    <section class="rec-section" id="programs">
      <span class="rec-label">Programs &amp; Delegations</span>
      <div class="rec-items">
        <div class="rec-item">
          <div class="rec-item-title"><a href="https://asiasociety.org/australia/meet-2025-asian-australian-voices-cohort" target="_blank" rel="noopener">Asian Australian Voices</a> · 2025</div>
          <div class="rec-item-detail">An Asia Society Australia and Australian Government initiative selecting up to 21 Asian Australian professionals for 12 months of intensive media and public policy training. The goal: inject fresh insights into the national conversation on Australia's relations with Asia, advance Australian prosperity and security in the region, and improve the representation of Asian Australians in public and corporate life.</div>
        </div>
        <div class="rec-item">
          <div class="rec-item-title"><a href="https://aiyd.org/aiyd-2024/" target="_blank" rel="noopener">Australia India Youth Dialogue (AIYD)</a> · 2024</div>
          <div class="rec-item-detail">Selected as part of the Australian delegation. The pre-eminent track-two young leaders' dialogue between Australia and India, bringing together 15 of the best and brightest young minds from each country. Held alternately in Australia and India, the AIYD fosters enduring people-to-people relationships and collaborative initiatives that create sustainable outcomes for both countries.</div>
        </div>
      </div>
    </section>

  </div>

</Base>

<style>
  .page-header {
    padding: 3rem 0 2rem;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.75rem;
  }

  .intro {
    font-family: 'Lora', serif;
    font-size: 1.1rem;
    color: #555;
    max-width: 600px;
    line-height: 1.7;
  }

  .content { max-width: 750px; }

  /* ── Pill nav ── */
  .pill-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 50;
    padding: 0.75rem 0;
    border-bottom: 1px solid #e5e5e5;
    margin-left: -2rem;
    margin-right: -2rem;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .pill {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #666;
    text-decoration: none;
    padding: 0.35rem 0.9rem;
    border: 1px solid #ddd;
    border-radius: 20px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .pill:hover {
    color: #c2613f;
    border-color: #c2613f;
    background: #fdf5f2;
  }

  .pill.active {
    color: #fff;
    background: #c2613f;
    border-color: #c2613f;
  }

  /* ── Sections ── */
  .rec-section {
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #e5e5e5;
    scroll-margin-top: 4rem;
  }

  .rec-section:last-of-type {
    border-bottom: none;
  }

  .rec-label {
    display: block;
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 1rem;
  }

  .rec-items {
    border-left: 2px solid #e8d5ce;
    padding-left: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .rec-item-title {
    font-family: 'Lora', serif;
    font-weight: 600;
    font-size: 1rem;
    color: #1a1a1a;
    line-height: 1.4;
    margin-bottom: 0.3rem;
  }

  .rec-item-detail {
    font-family: 'Lora', serif;
    font-size: 0.9rem;
    color: #555;
    line-height: 1.65;
  }
</style>

<script>
  const pills = document.querySelectorAll<HTMLAnchorElement>('.pill');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      pills.forEach((p) => p.classList.remove('active'));
      pill.classList.add('active');
    });
  });
</script>
