---
import Base from '../layouts/Base.astro';
---

<Base title="Recognition" description="Awards, honours, delegations, and media recognition for Nikhil Kulkarni.">

  <div class="page-header">
    <h1>Recognition</h1>
    <p class="intro">Awards, honours, delegations, and appearances — a record of the work and its reception.</p>
  </div>

  <section>
    <h2>Awards &amp; Honours</h2>
    <ul class="recognition-list">
      <li>
        <span class="item-title">Global Talent Independent (GTI) Visa — now National Innovation Visa</span>
        <span class="item-detail">Awarded by the Australian Government. Granted only to individuals recognised as exceptional global talent.</span>
      </li>
      <li>
        <span class="item-title">Asian Australian Leadership Awards — Finalist, Corporate Category</span>
        <span class="item-detail">Recognition for leadership and contribution by Asian Australians in the corporate sector.</span>
      </li>
      <li>
        <span class="item-title">India-Australia Business Community Alliance Award — Finalist</span>
        <span class="item-detail">Recognition for contribution to the Australia–India business community.</span>
      </li>
    </ul>
  </section>

  <section>
    <h2>Programs &amp; Delegations</h2>
    <ul class="recognition-list">
      <li>
        <span class="item-title">Asian Australian Voices Program</span>
        <span class="item-detail">One of 21 leaders selected for the inaugural cohort. A program recognising emerging Asian Australian voices in public life.</span>
      </li>
      <li>
        <span class="item-title">Australia India Youth Dialogue (AIYD) — Delegate, 2024</span>
        <span class="item-detail">Selected as a delegate for the flagship bilateral dialogue between emerging Australian and Indian leaders.</span>
      </li>
      <li>
        <span class="item-title">Program Director, New India House at SXSW Sydney 2025</span>
        <span class="item-detail">Led the program bringing together leaders across technology, entrepreneurship, culture, and policy at one of the world's leading innovation festivals.</span>
      </li>
      <li>
        <span class="item-title">Ambassador, LBW Trust — from 2026</span>
        <span class="item-detail">Cricket-funded charity supporting education across India, Nepal, Sri Lanka, Indonesia, and Australia. Alongside international cricketers.</span>
      </li>
      <li>
        <span class="item-title">NSW Management Committee, Australia India Business Council (AIBC)</span>
        <span class="item-detail">Elected committee member for the peak Australia–India business body in New South Wales.</span>
      </li>
      <li>
        <span class="item-title">Part-time Fellow, iSPIRT</span>
        <span class="item-detail">India's leading software product think tank. Designed and scaled programs supporting thousands of software product entrepreneurs (2006–2017).</span>
      </li>
    </ul>
  </section>

  <section>
    <h2>Broadcasting &amp; TV</h2>
    <ul class="recognition-list">
      <li>
        <span class="item-title">Mastermind — BBC / UKTV</span>
        <span class="item-detail">Appeared twice on the iconic quiz programme. One of the most demanding general knowledge formats on television.</span>
      </li>
      <li>
        <span class="item-title">University Challenge — BBC Two</span>
        <span class="item-detail">Appeared on the UK's premier university quiz competition.</span>
      </li>
      <li>
        <span class="item-title">Channel 9 Today Extra</span>
        <span class="item-detail">Featured as author of <em>My Summer of Cricket</em>.</span>
      </li>
      <li>
        <span class="item-title">ABC Radio</span>
        <span class="item-detail">Interviewed on ABC Radio Australia on cricket, migration, and the book.</span>
      </li>
      <li>
        <span class="item-title">SBS</span>
        <span class="item-detail">Appeared on SBS covering the Australia–India intersection and community perspectives.</span>
      </li>
    </ul>
  </section>

  <section>
    <h2>Speaking</h2>
    <ul class="recognition-list">
      <li>
        <span class="item-title">15+ speaking engagements (2009–2025)</span>
        <span class="item-detail">Keynotes, panels, fireside chats, webinars, and guest lectures across Australia and internationally. Represented Atlassian at global forums and industry panels.</span>
      </li>
      <li>
        <span class="item-title">SXSW Sydney</span>
        <span class="item-detail">Speaker and Program Director at one of Australia's largest innovation and culture festivals.</span>
      </li>
    </ul>
  </section>

</Base>

<style>
  .page-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 3rem;
  }

  h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.75rem;
  }

  .intro {
    font-family: 'Lora', serif;
    font-size: 1.1rem;
    color: #555;
    max-width: 600px;
    line-height: 1.7;
  }

  section {
    margin-bottom: 3.5rem;
    max-width: 750px;
  }

  h2 {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 1.5rem;
  }

  .recognition-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .recognition-list li {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.1rem 0 1.1rem 1.25rem;
    border-left: 3px solid #e8d5ce;
    border-bottom: 1px solid #f0f0f0;
    transition: border-left-color 0.2s;
  }

  .recognition-list li:last-child {
    border-bottom: none;
  }

  .recognition-list li:hover {
    border-left-color: #c2613f;
  }

  .item-title {
    font-family: 'Lora', serif;
    font-weight: 600;
    font-size: 1rem;
    color: #1a1a1a;
    line-height: 1.4;
  }

  .item-detail {
    font-family: 'Lora', serif;
    font-size: 0.9rem;
    color: #555;
    line-height: 1.65;
  }
</style>
