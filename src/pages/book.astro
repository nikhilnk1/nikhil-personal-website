<style>
  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 3rem;
    max-width: 760px;
  }

  .page-label {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c2613f;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.75rem;
  }

  .intro {
    font-family: 'Lora', serif;
    font-size: 1.1rem;
    color: #555;
    line-height: 1.75;
  }

  .content { max-width: 760px; }

  .book-hero {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #e5e5e5;
    align-items: start;
  }

  .book-cover img {
    width: 100%;
    display: block;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }

  h2 {
    font-family: 'Lora', serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 1rem;
  }

  p {
    font-family: 'Lora', serif;
    font-size: 1rem;
    color: #474747;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  em { font-style: italic; }

  .cta-btn {
    display: inline-block;
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    background: #c2613f;
    color: #fff;
    text-decoration: none;
    padding: 0.65rem 1.4rem;
    border-radius: 4px;
    transition: background 0.2s;
    margin-top: 0.5rem;
  }

  .cta-btn:hover { background: #a84e30; }

  .section {
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .section:last-child { border-bottom: none; }

  .themes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .theme {
    padding: 1.25rem;
    background: #fafafa;
    border-top: 3px solid #c2613f;
  }

  h3 {
    font-family: 'Lora', serif;
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.4rem;
  }

  .theme p {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.65;
    margin: 0;
  }

  .media-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .media-item.featured .media-outlet {
    color: #c2613f;
  }

  .media-outlet {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: #1a1a1a;
    min-width: 220px;
    flex-shrink: 0;
  }

  .media-detail {
    font-family: 'Lora', serif;
    font-size: 0.9rem;
    color: #666;
    flex: 1;
  }

  .media-link {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #c2613f;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .media-link:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .book-hero {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .book-cover { max-width: 180px; }
    .media-item { flex-wrap: wrap; }
    .media-outlet { min-width: unset; width: 100%; }
  }
</style>
