---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allHighlights = await getCollection('highlights');
const highlights = allHighlights
  .filter(h => h.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const typeLabel: Record<string, string> = {
  article: 'Published',
  event: 'Speaking',
  media: 'In the Media',
  note: 'Note',
  update: 'Update',
};
---

<Base title="Home" description="Sydney-based technology leader, author, and community builder.">

  <section class="hero">
    <div class="hero-img-wrap">
      <img src="/images/hero-speaking-stage.png" alt="Nikhil Kulkarni speaking on stage" class="hero-img" />
    </div>
    <div class="hero-text">
      <h1>Hi, I'm Nikhil.</h1>
      <p class="hero-sub">Nice to meet you.</p>
      <hr class="hero-rule" />
    </div>
  </section>

  <div class="bio">
    <p class="bio-lead">I create impact at the intersection of <em class="bio-accent">technology</em>, <em class="bio-accent">community</em>, and <em class="bio-accent">creativity</em>.</p>
    <p>I'm passionate about using technology for positive impact. I bring nearly two decades of technology leadership experience across Australia and India, with senior roles at <a href="/atlassian">Atlassian</a> in Australia and <a href="/flipkart">Flipkart</a> in India. Most recently, as founding Product Lead in Atlassian's Central AI team, I played a key role in launching Rovo, Atlassian's AI product, and taking it to enterprise customers at scale. With AI in particular, I think deeply about where it creates genuine value and how to keep the human element strong.</p>
    <p>I strongly believe in paying it forward and bring impactful community leadership experience, currently <a href="/australia-india">bridging Australia and India</a> across technology, talent, and culture. My work has been recognised through awards and leadership programs in both countries. I am an Ambassador of <a href="/lbw-trust">The LBW Trust</a>, a cricket-based charity, and a former part-time Fellow at <a href="/ispirit">iSPIRT</a>, the think tank behind India's Digital Public Infrastructure.</p>
    <p>A curious creative at heart, my creative pursuits energise me as much as my professional ones. My book, <a href="/book"><em>My Summer of Cricket</em></a>, has received widespread coverage and acclaim across the cricketing world. My <a href="/op-ed-and-media-commentary">opinion pieces</a> on sport, technology, and culture have appeared in The Sydney Morning Herald, The Australian Financial Review, and other major outlets. I enjoy trivia and have been on prestigious quiz shows like Mastermind and University Challenge.</p>
  </div>

  <section class="highlights">
    <div class="highlights-header">
      <h2 class="highlights-heading">Recent highlights</h2>
      <div class="carousel-controls">
        <button id="highlights-prev" class="carousel-btn" aria-label="Previous" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button id="highlights-next" class="carousel-btn" aria-label="Next">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
    <div class="highlights-grid" id="highlights-track">
      {highlights.map((item) => (
        <article class={`highlight-card type-${item.data.type}`}>
          {item.data.image && (
            item.data.url
              ? <a href={item.data.url} target="_blank" rel="noopener" class="highlight-img-link">
                  <div class="highlight-img-wrap">
                    <img src={item.data.image} alt="" class="highlight-img" loading="lazy" />
                  </div>
                </a>
              : <div class="highlight-img-wrap">
                  <img src={item.data.image} alt="" class="highlight-img" loading="lazy" />
                </div>
          )}
          <div class="highlight-body">
            <div class="highlight-top">
              <span class="highlight-type">{typeLabel[item.data.type]}</span>
              <time class="highlight-date" datetime={item.data.date.toISOString()}>
                {item.data.date.toLocaleDateString('en-AU', { month: 'long', year: 'numeric' })}
              </time>
            </div>
            {item.data.publication && <span class="highlight-pub">{item.data.publication}</span>}
            <h3 class="highlight-title">
              {item.data.url
                ? <a href={item.data.url} target="_blank" rel="noopener">{item.data.title}</a>
                : item.data.title}
            </h3>
            <p class="highlight-summary">{item.data.summary}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

</Base>

<style>
  .hero {
    display: flex;
    align-items: stretch;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    min-height: clamp(340px, 50vh, 520px);
    margin-top: -3rem;
    margin-bottom: 2rem;
    overflow: hidden;
    background: #f4f1ec;
  }

  .hero-text {
    flex: 0 0 48%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 3rem max(2.5rem, calc(50vw - 530px)) 3.5rem 3rem;
  }

  .hero-img-wrap {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .hero-img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 75%, #f4f1ec 100%);
    pointer-events: none;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 30% 0%;
  }

  h1 {
    font-family: 'Lora', serif;
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    font-weight: 600;
    line-height: 1.05;
    color: #1a1a1a;
    margin: 0 0 0.4rem;
    white-space: nowrap;
  }

  .hero-sub {
    font-family: 'Lora', serif;
    font-size: clamp(1.6rem, 3.2vw, 3.2rem);
    font-weight: 400;
    font-style: italic;
    color: #666;
    margin: 0 0 1.2rem;
    line-height: 1.2;
  }

  .hero-rule {
    border: none;
    border-top: 3px solid #c2613f;
    margin: 0;
    width: 60px;
  }

  .bio {
    margin: 0 0 4rem;
    font-family: 'Lora', serif;
  }

  .bio-lead {
    font-size: clamp(1.3rem, 2.2vw, 1.7rem) !important;
    font-weight: 600;
    color: #1a1a1a !important;
    margin-bottom: 0.75rem !important;
  }

  .bio-accent {
    color: #c2613f;
    font-style: italic;
    font-weight: 600;
  }

  .bio p {
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    color: #333;
    line-height: 1.85;
    margin-bottom: 1.5rem;
  }

  .bio p:last-child {
    margin-bottom: 0;
  }

  .bio a {
    color: #1a1a1a;
    text-decoration: none;
    border-bottom: 1.5px solid #c2613f;
    transition: color 0.2s;
  }

  .bio a:hover {
    color: #a84e30;
  }


  /* ── Highlights ── */
  .highlights {
    margin-bottom: 4rem;
  }

  .highlights-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .highlights-heading {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #999;
    margin: 0;
  }

  .carousel-controls {
    display: flex;
    gap: 0.5rem;
  }

  .carousel-btn {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1.5px solid #ddd;
    background: #fff;
    color: #555;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    padding: 0;
  }

  .carousel-btn:hover:not(:disabled) {
    border-color: #c2613f;
    color: #c2613f;
    background: #fdf5f2;
  }

  .carousel-btn:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .highlights-grid {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    margin-right: -2rem;
    padding-right: 2rem;
    scrollbar-width: none;
  }

  .highlights-grid::-webkit-scrollbar { display: none; }

  .highlight-card {
    flex: 0 0 300px;
    scroll-snap-align: start;
    border-top: 3px solid #c2613f;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .highlight-img-link {
    display: block;
  }

  .highlight-img-wrap {
    width: 100%;
    height: 160px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .highlight-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.3s ease;
  }

  .highlight-card:hover .highlight-img {
    transform: scale(1.03);
  }

  .highlight-body {
    padding: 1.1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .highlight-top {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .highlight-type {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #999;
  }

  .highlight-title {
    font-family: 'Lora', serif;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: #c2613f;
    margin: 0;
  }

  .highlight-title a {
    color: #c2613f;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .highlight-title a:hover {
    opacity: 0.75;
  }

  .highlight-summary {
    font-family: 'Lora', serif;
    font-size: 0.9rem;
    color: #555;
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }

  .highlight-date {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.72rem;
    color: #999;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .highlight-pub {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: #999;
    margin-bottom: 0.2rem;
  }

  @media (max-width: 640px) {
    .highlight-card { flex: 0 0 80vw; }
    .highlights-grid { margin-right: -1rem; padding-right: 1rem; }
  }

  @media (max-width: 640px) {
    .hero {
      flex-direction: column;
      min-height: unset;
    }

    .hero-img-wrap {
      height: 72vw;
      flex: none;
    }

    .hero-img {
      object-position: 50% 0%;
    }

    .hero-img-wrap::after {
      background: linear-gradient(to bottom, transparent 40%, #f4f1ec 100%);
    }

    .hero-text {
      flex: none;
      padding: 0 1.5rem 1.5rem;
      margin-top: -5rem;
      position: relative;
      z-index: 1;
    }

    h1 {
      white-space: normal;
      font-size: clamp(2.4rem, 11vw, 3.4rem);
    }

    .hero-sub {
      font-size: clamp(1.3rem, 6vw, 1.8rem);
    }
  }
</style>

<script>
  const track = document.getElementById('highlights-track') as HTMLElement;
  const prevBtn = document.getElementById('highlights-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('highlights-next') as HTMLButtonElement;

  function getScrollStep() {
    const card = track.querySelector('.highlight-card') as HTMLElement;
    return card ? card.offsetWidth + 24 : 320;
  }

  function updateButtons() {
    prevBtn.disabled = track.scrollLeft <= 4;
    nextBtn.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 4;
  }

  prevBtn.addEventListener('click', () => {
    track.scrollBy({ left: -getScrollStep(), behavior: 'smooth' });
  });

  nextBtn.addEventListener('click', () => {
    track.scrollBy({ left: getScrollStep(), behavior: 'smooth' });
  });

  track.addEventListener('scroll', updateButtons, { passive: true });
  updateButtons();
</script>

