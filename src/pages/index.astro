---
import Base from '../layouts/Base.astro';
---

<Base title="Home" description="Sydney-based technology leader, author, and community builder.">

  <section class="hero">
    <img src="/images/hero-speaking.jpg" alt="" class="hero-bg" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Hi, I'm Nikhil.</h1>
      <p class="hero-sub">Nice to meet you.</p>
      <hr class="hero-rule" />
    </div>
  </section>

  <p class="intro">
    I am an <a href="/ai-product">AI and Product Management leader</a>,
    an active <a href="/australia-india">community voice and ecosystem builder</a>
    and <a href="/writing">author and commentator</a>.
    I enjoy trivia and love a good pun!
  </p>



</Base>

<style>
  .hero {
    position: relative;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    height: clamp(320px, 46vh, 480px);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    margin-bottom: 3rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to left, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.4) 45%, rgba(0,0,0,0.0) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.0) 50%, rgba(0,0,0,0.25) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 0 5rem 1.5rem 2rem;
    max-width: 640px;
  }

  h1 {
    font-family: 'Lora', serif;
    font-size: clamp(3.4rem, 6vw, 6rem);
    font-weight: 600;
    line-height: 1.05;
    color: #fff;
    margin: 0 0 0.4rem;
    white-space: nowrap;
  }

  .hero-sub {
    font-family: 'Lora', serif;
    font-size: clamp(1.9rem, 3.8vw, 3.6rem);
    font-weight: 400;
    font-style: italic;
    color: rgba(255,255,255,0.85);
    margin: 0 0 1.2rem;
    line-height: 1.2;
  }

  .hero-rule {
    border: none;
    border-top: 2px solid #5eead4;
    margin: 0;
    width: 60px;
  }

  .intro {
    font-family: 'Lora', serif;
    font-size: clamp(1.4rem, 2.9vw, 2rem);
    color: #1a1a1a;
    line-height: 1.6;
    margin: 2.5rem 0 3rem;
  }

  .intro a {
    color: #1a1a1a;
    text-decoration: none;
    border-bottom: 2px solid #5eead4;
    transition: color 0.2s;
  }

  .intro a:hover {
    color: #0d9488;
  }


  .pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .pillar-card {
    display: block;
    padding: 1.75rem;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .pillar-card:hover {
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  /* Photo strip cards — remove default padding, re-apply inside */
  .card-ai,
  .card-india,
  .card-book,
  .card-writing {
    padding: 0;
  }

  .card-ai h2, .card-ai p,
  .card-india h2, .card-india p,
  .card-book h2, .card-book p,
  .card-writing h2, .card-writing p {
    padding: 0 1.75rem;
  }

  .card-ai h2, .card-india h2,
  .card-book h2, .card-writing h2 {
    padding-top: 1.25rem;
  }

  .card-ai p, .card-india p,
  .card-book p, .card-writing p {
    padding-bottom: 1.75rem;
  }

  .card-image {
    width: 100%;
    height: 160px;
    overflow: hidden;
    border-radius: 7px 7px 0 0;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  /* Coloured borders per pillar */
  .card-ai      { border-color: #2563eb; }
  .card-india   { border-color: #f59e0b; }
  .card-writing { border-color: #16a34a; }
  .card-book    { border-color: #dc2626; }

  /* Zoom in on the Australia-India card */
  .card-india .card-image img {
    transform: scale(1.3);
    transform-origin: center center;
  }

  /* Shift book card left so the name lower-third is visible */
  .card-book .card-image img {
    object-position: left center;
  }

  .pillar-card h2 {
    font-family: 'Lora', serif;
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
  }

  .pillar-card p {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
  }

  .now {
    padding: 1.5rem;
    background: #f9f9f9;
    border-radius: 8px;
    font-size: 0.95rem;
    color: #444;
  }

  .now a {
    color: #1a1a1a;
    font-weight: 500;
    margin-left: 0.5rem;
  }

  @media (max-width: 640px) {
    .hero-content {
      padding: 0 1.5rem 2.5rem;
      max-width: 100%;
    }

    h1 {
      white-space: normal;
    }
  }
</style>
