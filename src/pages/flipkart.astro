---
import Base from '../layouts/Base.astro';
---

<Base title="Flipkart & Indian Startups" description="Nikhil Kulkarni's product leadership at Flipkart and work within India's startup ecosystem.">

  <div class="page-header">
    <h1>Flipkart &amp; Indian Startups</h1>
    <p class="intro">Product leadership at Flipkart — building products at scale across e-commerce logistics and digital media — and early involvement in India's startup and software product ecosystem.</p>
  </div>

  <div class="placeholder-notice">
    <p>Full page coming soon.</p>
    <a href="/contact" class="cta-btn">Get in touch</a>
  </div>

</Base>

<style>
  .page-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 3rem;
    max-width: 700px;
  }

  h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.75rem;
  }

  .intro {
    font-family: 'Lora', serif;
    font-size: 1.1rem;
    color: #555;
    line-height: 1.75;
  }

  .placeholder-notice {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 2.5rem;
    background: #fdf5f2;
    border-left: 4px solid #c2613f;
    max-width: 560px;
  }

  .placeholder-notice p {
    font-family: 'Lora', serif;
    font-size: 1rem;
    color: #555;
    margin: 0;
  }

  .cta-btn {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    background: #c2613f;
    color: #fff;
    text-decoration: none;
    padding: 0.6rem 1.2rem;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .cta-btn:hover { background: #a84e30; }
</style>
