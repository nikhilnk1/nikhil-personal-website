---
import Base from '../layouts/Base.astro';
---

<Base title="In the Media" description="Nikhil Kulkarni's media appearances: Channel 9, ABC Radio, SBS, and podcasts.">

  <div class="page-header">
    <p class="page-label">About</p>
    <h1>In the Media</h1>
    <p class="intro">Television, radio, podcast, and press appearances across Australia and India — on cricket fandom, authorship, sport and inclusion, the Australia–India relationship, and trivia.</p>
  </div>

  <div class="content">

    <nav class="pill-nav" aria-label="Jump to section">
      <a href="#television" class="pill">Television</a>
      <a href="#radio" class="pill">Radio</a>
      <a href="#podcasts" class="pill">Podcasts</a>
      <a href="#press" class="pill">Press</a>
    </nav>

    <section class="media-section" id="television">
      <h2 class="section-label">Television</h2>

      <div class="media-embed-item">
        <div class="media-outlet">Channel 9: Today Extra <span class="year">· November 2025</span></div>
        <div class="media-detail">Interview on <em>My Summer of Cricket</em></div>
        <div class="embed-wrap">
          <iframe
            src="https://www.youtube.com/embed/3u32GKL4T9g"
            title="Channel 9 Today Extra: My Summer of Cricket"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <div class="media-embed-item">
        <div class="media-outlet">Mastermind Australia <span class="year">· 2024</span></div>
        <div class="media-detail">Contestant</div>
        <div class="embed-wrap">
          <iframe
            src="https://www.youtube.com/embed/FH66X_YsdtU"
            title="Mastermind Australia 2024"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <div class="media-embed-item">
        <div class="media-outlet">Mastermind Australia <span class="year">· 2020</span></div>
        <div class="media-detail">Contestant</div>
        <div class="embed-wrap">
          <iframe
            src="https://www.youtube.com/embed/OQg27gKyV54"
            title="Mastermind Australia 2020"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <section class="media-section" id="radio">
      <h2 class="section-label">Radio</h2>

      <div class="media-embed-item">
        <div class="media-outlet">ABC Radio Sydney Breakfast <span class="year">· October 2025</span></div>
        <div class="media-detail">With Craig Reucassel · <em>My Summer of Cricket</em></div>
        <div class="embed-wrap embed-wrap--compact">
          <iframe
            src="https://www.youtube.com/embed/V4lMes--_Z4"
            title="ABC Radio Sydney Breakfast: My Summer of Cricket"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <div class="media-embed-item">
        <div class="media-outlet">ABC Radio Adelaide: SA &amp; NT Evenings <span class="year">· October 2025</span></div>
        <div class="media-detail">With Spence Denny · <em>My Summer of Cricket</em></div>
        <div class="embed-wrap embed-wrap--compact">
          <iframe
            src="https://www.youtube.com/embed/TH1V6_LWkP0"
            title="ABC Radio Adelaide: My Summer of Cricket"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <div class="media-item">
        <div class="media-info">
          <div class="media-outlet">ABC Radio National: Life Matters <span class="year">· November 2025</span></div>
          <div class="media-detail">Closing sport's gender play gap</div>
        </div>
        <a href="https://www.abc.net.au/listen/programs/lifematters/closing-sport-gender-play-gap/106034194" target="_blank" rel="noopener" class="media-link">Listen →</a>
      </div>

      <div class="media-item">
        <div class="media-info">
          <div class="media-outlet">4BC Brisbane: Mornings with Ben Davis <span class="year">· December 2025</span></div>
          <div class="media-detail"><em>My Summer of Cricket</em> during the Ashes</div>
        </div>
        <a href="https://www.instagram.com/reel/DS2t-DpjMnZ/" target="_blank" rel="noopener" class="media-link">Listen →</a>
      </div>

      <div class="media-item">
        <div class="media-info">
          <div class="media-outlet">Radio 5AA Adelaide: Afternoons with Angie McBride <span class="year">· February 2026</span></div>
          <div class="media-detail"><em>My Summer of Cricket</em></div>
        </div>
        <a href="https://www.instagram.com/reel/DVKhJTjj5ip/" target="_blank" rel="noopener" class="media-link">Listen →</a>
      </div>

      <div class="media-item">
        <div class="media-info">
          <div class="media-outlet">SBS Hindi <span class="year">· November 2025</span></div>
          <div class="media-detail">Interview with Natasha Kaul · <em>My Summer of Cricket</em></div>
        </div>
        <a href="https://www.sbs.com.au/language/hindi/en/podcast-episode/debut-book-by-nikhil-kulkarni-celebrates-cricket-as-a-passionate-love-letter-to-the-game/l580pyr9h" target="_blank" rel="noopener" class="media-link">Listen →</a>
      </div>
    </section>

    <section class="media-section" id="podcasts">
      <h2 class="section-label">Podcasts</h2>

      <div class="media-embed-item">
        <div class="media-outlet">Chats Over Chai <span class="year">· November 2025</span></div>
        <div class="media-detail">With The Hon. Lisa Singh</div>
        <iframe
          style="border-radius:8px"
          src="https://open.spotify.com/embed/episode/2wpMdicWt95zkCI5r05XvD?utm_source=generator"
          width="100%"
          height="152"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
        ></iframe>
      </div>

      <div class="media-embed-item">
        <div class="media-outlet">Conversations with Sports Fans <span class="year">· November 2025</span></div>
        <div class="media-detail">Cricket Tragic · with Douglas Hill</div>
        <iframe
          style="border-radius:8px"
          src="https://open.spotify.com/embed/episode/42CNNFlhadVcEAKIDE5luy?utm_source=generator"
          width="100%"
          height="152"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
        ></iframe>
      </div>

      <div class="media-embed-item">
        <div class="media-outlet">Sport Nation Afternoon <span class="year">· December 2025</span></div>
        <div class="media-detail">With Mark Stafford</div>
        <iframe
          style="border-radius:8px"
          src="https://open.spotify.com/embed/episode/4qsiryMXNfQRxz18Zh0hyO?utm_source=generator"
          width="100%"
          height="152"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
        ></iframe>
      </div>
    </section>

    <section class="media-section" id="press">
      <h2 class="section-label">Press</h2>

      <div class="media-item">
        <div class="media-info">
          <div class="media-outlet">Indian Link: Book Review <span class="year">· October 2025</span></div>
          <div class="media-detail">Review of <em>My Summer of Cricket</em></div>
        </div>
        <a href="https://www.indianlink.com.au/book-review-nikhil-kulkarnis-my-summer-of-cricket/" target="_blank" rel="noopener" class="media-link">Read →</a>
      </div>

      <div class="media-item">
        <div class="media-info">
          <div class="media-outlet">Frontlist <span class="year">· June 2026</span></div>
          <div class="media-detail">Author interview: what makes a true cricket fan?</div>
        </div>
        <a href="https://www.frontlist.in/interview-with-nikhil-kulkarni-author-of-my-summer-of-cricket" target="_blank" rel="noopener" class="media-link">Read →</a>
      </div>
    </section>

    <div class="cta-block">
      <p>For media enquiries, please <a href="/contact">get in touch</a>. For op-eds and opinion writing, see the <a href="/writing">Writing page</a>.</p>
    </div>

  </div>

</Base>

<style>
  .page-header {
    padding: 3rem 0 2rem;
    margin-bottom: 1.5rem;
    max-width: 760px;
  }

  .page-label {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c2613f;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.75rem;
  }

  .intro {
    font-family: 'Lora', serif;
    font-size: 1.1rem;
    color: #555;
    line-height: 1.75;
  }

  .content { max-width: 760px; }

  /* ── Pill nav ── */
  .pill-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 50;
    padding: 0.75rem 0;
    border-bottom: 1px solid #e5e5e5;
    margin-left: -2rem;
    margin-right: -2rem;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .pill {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #666;
    text-decoration: none;
    padding: 0.35rem 0.9rem;
    border: 1px solid #ddd;
    border-radius: 20px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .pill:hover {
    color: #c2613f;
    border-color: #c2613f;
    background: #fdf5f2;
  }

  .pill.active {
    color: #fff;
    background: #c2613f;
    border-color: #c2613f;
  }

  /* ── Sections ── */
  .media-section {
    margin-bottom: 3.5rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid #e5e5e5;
    scroll-margin-top: 4rem;
  }

  .media-section:last-of-type {
    border-bottom: none;
  }

  .section-label {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1a1a1a;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #1a1a1a;
  }

  /* ── Media items ── */
  .media-embed-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .media-embed-item:last-child { border-bottom: none; }

  .media-embed-item .media-outlet { margin-bottom: 0.2rem; }
  .media-embed-item .media-detail { margin-bottom: 0.75rem; }

  .embed-wrap {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 4px;
  }

  .embed-wrap--compact { padding-bottom: 35%; }

  .embed-wrap iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .media-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .media-item:last-child { border-bottom: none; }

  .media-outlet {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 0.2rem;
  }


  .media-detail {
    font-family: 'Lora', serif;
    font-size: 0.88rem;
    color: #666;
  }

  .media-link {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #c2613f;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .media-link:hover { text-decoration: underline; }

  .cta-block {
    margin-top: 1rem;
    padding: 1.5rem;
    background: #fdf5f2;
    border-left: 4px solid #c2613f;
  }

  .cta-block p {
    font-family: 'Lora', serif;
    font-size: 0.95rem;
    color: #474747;
    line-height: 1.7;
    margin: 0;
  }

  .cta-block a { color: #c2613f; }

  em { font-style: italic; }
</style>

<script>
  const pills = document.querySelectorAll<HTMLAnchorElement>('.pill');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      pills.forEach((p) => p.classList.remove('active'));
      pill.classList.add('active');
    });
  });
</script>
