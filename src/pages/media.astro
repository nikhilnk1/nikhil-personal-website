---
import Base from '../layouts/Base.astro';
---

<Base title="In the Media" description="Nikhil Kulkarni's media appearances — TV, radio, podcasts, and press coverage.">

  <div class="page-header">
    <h1>In the Media</h1>
    <p class="intro">TV appearances, radio interviews, podcast features, and press coverage — a record of Nikhil's public commentary across technology, cricket, and Australia–India affairs.</p>
  </div>

  <div class="placeholder-notice">
    <p>Full media page coming soon — appearances on Channel 9, ABC Radio, SBS, and podcast coverage of <em>My Summer of Cricket</em>.</p>
    <a href="/contact" class="cta-btn">Media enquiries</a>
  </div>

</Base>

<style>
  .page-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 3rem;
    max-width: 700px;
  }

  h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.75rem;
  }

  .intro {
    font-family: 'Lora', serif;
    font-size: 1.1rem;
    color: #555;
    line-height: 1.75;
  }

  .placeholder-notice {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 2.5rem;
    background: #fdf5f2;
    border-left: 4px solid #c2613f;
    max-width: 560px;
  }

  .placeholder-notice p {
    font-family: 'Lora', serif;
    font-size: 1rem;
    color: #555;
    margin: 0;
  }

  .cta-btn {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    background: #c2613f;
    color: #fff;
    text-decoration: none;
    padding: 0.6rem 1.2rem;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .cta-btn:hover {
    background: #a84e30;
  }
</style>
